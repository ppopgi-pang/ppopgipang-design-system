{
  "name": "@ppopgipang-ui/design-system",
  "description": "뽑기팡의 디자인 시스템",
  "license": "MIT",
  "author": "hani0903",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:icons": "svgr --typescript --icon --jsx-runtime automatic --replace-attr-values \"#000=currentColor\" --out-dir src/components/icon/components src/assets/icons && tsx scripts/generate-icon-index.ts && tsx scripts/generate-icon-map.ts"
  },
  "dependencies": {
    "@fontsource/pretendard": "^5.2.5",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@svgr/cli": "^8.1.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.5"
  }
}
